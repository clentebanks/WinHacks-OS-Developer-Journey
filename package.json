{
  "name": "winhacks-os-developer-journey",
  "version": "0.5.0",
  "private": true,
  "description": "Build WinHacks OS while documenting a complete Full Stack engineering journey.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "node scripts/check-repository.mjs",
    "doctor": "node scripts/doctor.mjs",
    "dev:cli": "node packages/cli/src/index.js",
    "build": "npm run check",
    "test": "node --test",
    "legacy:inventory": "node scripts/inventory-legacy.mjs",
    "test:logger": "node --test packages/core/tests/logger.test.js"
  },
  "keywords": [
    "winhacks",
    "nodejs",
    "typescript",
    "learning",
    "developer-tools",
    "seo",
    "geo"
  ],
  "author": "Clent Ebanks",
  "license": "MIT"
}
