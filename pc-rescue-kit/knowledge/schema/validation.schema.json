{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "type",
    "expected",
    "status",
    "version"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^VAL-[A-Z]{3,5}-[0-9]{3}$"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "expected": {
      "type": "string"
    },
    "failureMessage": {
      "type": "string"
    },
    "successNext": {
      "type": "string"
    },
    "failureNext": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
  }
}