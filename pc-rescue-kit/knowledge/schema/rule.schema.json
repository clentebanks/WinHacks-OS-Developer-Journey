{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "priority",
    "conditions",
    "actions",
    "status",
    "version"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^RULE-[A-Z]{3,5}-[0-9]{3}$"
    },
    "name": {
      "type": "string"
    },
    "priority": {
      "type": "integer"
    },
    "conditions": {
      "type": "array",
      "minItems": 1
    },
    "actions": {
      "type": "array",
      "minItems": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
  }
}