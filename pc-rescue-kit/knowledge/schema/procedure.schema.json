{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "name",
    "shortName",
    "category",
    "subcategory",
    "phase",
    "risk",
    "estimatedTime",
    "description",
    "goal",
    "whenUse",
    "whenNotUse",
    "requirements",
    "commands",
    "steps",
    "validation",
    "nextProcedures",
    "related",
    "windows",
    "status",
    "version"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^WHPRS-[A-Z]{3}-[0-9]{3}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 5
    },
    "shortName": {
      "type": "string",
      "minLength": 2
    },
    "category": {
      "type": "string"
    },
    "subcategory": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "risk": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "estimatedTime": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "goal": {
      "type": "string",
      "minLength": 10
    },
    "whenUse": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "whenNotUse": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "requiresAdmin"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "requiresAdmin": {
            "type": "boolean"
          },
          "shell": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "order",
          "title",
          "instruction"
        ],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string"
          },
          "instruction": {
            "type": "string"
          },
          "warning": {
            "type": "string"
          },
          "expectedResult": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "expected"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "expected": {
            "type": "string"
          },
          "failureMessage": {
            "type": "string"
          }
        }
      }
    },
    "failureActions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "condition",
          "nextProcedure"
        ],
        "properties": {
          "condition": {
            "type": "string"
          },
          "nextProcedure": {
            "type": "string",
            "pattern": "^WHPRS-[A-Z]{3}-[0-9]{3}$"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "nextProcedures": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^WHPRS-[A-Z]{3}-[0-9]{3}$"
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "windows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "articleUrl": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date"
    },
    "updatedAt": {
      "type": "string",
      "format": "date"
    }
  }
}